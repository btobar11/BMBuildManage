{
  "name": "bm-build-manage",
  "private": true,
  "packageManager": "npm@10.9.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "docs:generate": "npx tsx scripts/generate-docs.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npx turbo run lint -- --quiet",
      "cd apps/api && npx tsc --noEmit",
      "cd ../web && npx tsc --noEmit"
    ]
  },
  "dependencies": {
    "esbuild": "^0.28.0"
  },
  "overrides": {
    "typescript": "^5.7.0",
    "@csstools/css-parser-algorithms": "^3.0.5",
    "@csstools/css-tokenizer": "^3.0.4"
  }
}
