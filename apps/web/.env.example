# ==============================================================================
# BM BUILD MANAGE - VARIABLES DE ENTORNO (WEB)
# ==============================================================================
# Copia este archivo como .env y completa los valores para producción

# ============================================
# SUPABASE CLIENT
# ============================================
# Obtén de: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# API URL (Backend desplegado)
# ============================================
# Desarrollo: http://localhost:3001
# Producción: https://api.tu-dominio.com/api/v1
VITE_API_URL=http://localhost:3001

# ============================================
# ENVIRONMENT
# ============================================
# development | production
VITE_NODE_ENV=development