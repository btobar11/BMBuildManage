# ==============================================================================
# BM BUILD MANAGE - VARIABLES DE ENTORNO PRODUCCIÓN (API)
# ==============================================================================
# COPIA ESTE ARCHIVO COMO .env Y COMPLETA LOS VALORES

# ============================================
# DATABASE - Supabase PostgreSQL
# ==============================================================================
# Obtén esto de: Supabase Dashboard → Settings → Database → Connection String
# Formato: postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=

# ============================================
# SUPABASE
# ==============================================================================
# Obtén de: Supabase Dashboard → Settings → API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InR1LXB... (tu anon key)

# ⚠️ SOLO PARA USO INTERNO - NO EXPONER EN CLIENTE
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InR1LXB... (tu service role key)

# ============================================
# JWT AUTH - Generación de tokens
# ==============================================================================
# Genera un secret seguro: openssl rand -base64 32
JWT_SECRET=aquí-tu-jwt-secret-mínimo-32-caracteres-string-seguro
JWT_EXPIRES_IN=7d

# ============================================
# CORS - URLs permitidas (PRODUCCIÓN: NO USAR *)
# ==============================================================================
# URLs exactas separadas por coma - SIN espacios
FRONTEND_URL=https://bmbuildmanage.com
CORS_ORIGINS=https://bmbuildmanage.com,https://www.bmbuildmanage.com

# ============================================
# NODE ENVIRONMENT & PORT
# ==============================================================================
NODE_ENV=production
PORT=3001

# ============================================
# SECURITY - Dev Token
# ==============================================================================
# ⚠️ IMPORTANTE: FALSE en producción
ALLOW_DEV_TOKEN=false

# ============================================
# API CONFIGURATION
# ==============================================================================
# Prefijo de la API (no cambiar)
API_PREFIX=api/v1