# ==============================================================================
# BM BUILD MANAGE - VARIABLES DE ENTORNO
# ==============================================================================
# Copia este archivo como .env y completa los valores

# ============================================
# DATABASE - Supabase PostgreSQL
# ============================================
# Obtén de: Supabase Dashboard → Settings → Database → Connection String
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ============================================
# SUPABASE
# ============================================
# Obtén de: Supabase Dashboard → Settings → API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️ SOLO PARA BACKEND - NO EXPONER EN FRONTEND
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# JWT AUTH
# ============================================
# Genera: openssl rand -base64 32
JWT_SECRET=tu-jwt-secret-minimo-32-caracteres-aqui
JWT_EXPIRES_IN=7d

# ============================================
# CORS - URLs permitidas
# ============================================
# Desarrollo: http://localhost:5173,http://localhost:3000
# Producción: https://tu-dominio.com
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# NODE & PORT
# ============================================
NODE_ENV=development
PORT=3001

# ============================================
# SECURITY
# ============================================
# TRUE solo en desarrollo, FALSE en producción
ALLOW_DEV_TOKEN=true