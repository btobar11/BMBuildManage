# ==============================================================================
# BM BUILD MANAGE - VARIABLES DE ENTORNO
# ==============================================================================
# Copia este archivo como .env y completa los valores

# ============================================
# DATABASE - Supabase PostgreSQL
# ============================================
# Obtén de: Supabase Dashboard → Settings → Database → Connection String
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ============================================
# SUPABASE
# ============================================
# Obtén de: Supabase Dashboard → Settings → API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️ SOLO PARA BACKEND - NO EXPONER EN FRONTEND
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# JWT AUTH
# ============================================
# Genera: openssl rand -base64 32
JWT_SECRET=tu-jwt-secret-minimo-32-caracteres-aqui
JWT_EXPIRES_IN=7d

# ============================================
# CORS - URLs permitidas
# ============================================
# Desarrollo: http://localhost:5173,http://localhost:3000
# Producción: https://tu-dominio.com
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# NODE & PORT
# ============================================
NODE_ENV=development
PORT=3001

# ============================================
# SECURITY
# ============================================
# TRUE solo en desarrollo, FALSE en producción
ALLOW_DEV_TOKEN=true

# Seed endpoint (dev only)
ALLOW_SEED_ENDPOINT=false

# ============================================
# AI - GROQ (Llama 3.1 70B)
# ============================================
# Obtén tu API key en: https://console.groq.com/keys
# Modelos disponibles: llama-3.1-70b-versatile, llama-3.1-405b-reasoning, mixtral-8x7b-32768
GROQ_API_KEY=tu-groq-api-key-aqui
GROQ_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.1-70b-versatile
